-- future reference for installing elsa: 
-- cabal update && cabal install elsa --overwrite-policy=always

--------------------------------------------------------------------------------
-- Booleans
--------------------------------------------------------------------------------

let TRUE  = \x y -> x
let FALSE = \x y -> y
let ITE   = \b x y -> b x y
let AND   = \b1 b2 -> ITE b1 b2 FALSE
let OR    = \b1 b2 -> ITE b1 TRUE b2

--------------------------------------------------------------------------------
-- Numbers
--------------------------------------------------------------------------------

let ZERO  = \f x -> x
let ONE   = \f x -> f x
let TWO   = \f x -> f (f x)
let INCR  = \n f x -> f (n f x)

--------------------------------------------------------------------------------
-- Pairs
--------------------------------------------------------------------------------

let PAIR  = \x y b -> ITE b x y
let FST   = \p     -> p TRUE
let SND   = \p     -> p FALSE

--------------------------------------------------------------------------------
-- WORKSHEET 2 PART 1
--------------------------------------------------------------------------------

let NOT = \b -> ITE b FALSE TRUE
let INCRFLIP = \p -> (PAIR (INCR (FST p)) (NOT (SND p)))

--------------------------------------------------------------------------------
-- WORKSHEET 2 PART 1 TESTS
--------------------------------------------------------------------------------

eval not_test1 :
    NOT TRUE
    =~> FALSE

eval not_test2 :
    NOT FALSE
    =~> TRUE

eval not_test3 :
    NOT (AND FALSE TRUE)
    =~> TRUE

eval not_test4 :
    NOT (NOT (NOT FALSE))
    =~> TRUE

eval incrflip_test1 : 
    INCRFLIP (PAIR ONE FALSE)
    =~> (\b -> b TWO TRUE)

eval incrflip_test2 : 
    INCRFLIP (PAIR ZERO TRUE)
    =~> (\b -> b ONE FALSE)

eval incrflip_test3 : 
    INCRFLIP (PAIR TWO TRUE)
    =~> (\b -> b (\f x -> f(f(f x))) FALSE)